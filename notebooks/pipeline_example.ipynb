  "kernelspec": {\"display_name\": \"Python 3\", \"language\": \"python\", \"name\": \"python3\"},\n  \"language_info\": {\"name\": \"python\", \"version\": \"3.11\"}\n },\n \"nbformat\": 4,\n \"nbformat_minor\": 4\n}\n