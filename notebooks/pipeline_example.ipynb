{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# sebal-et-gee — End-to-end pipeline example\n",
    "\n",
    "A single clean notebook that runs the full SEBAL pipeline over the Turkish Thrace region\n",
    "using the modular `sebal` package.\n",
    "\n",
    "**Inputs:** Landsat 8+9 C02 L2, ERA5-Land hourly.\n",
    "**Output:** daily ET map (mm/day) at 30 m resolution.\n",
    "\n",
    "The reference case runs over a 14-day window centered on 2023-07-20, which gives\n",
    "99.7% AOI coverage after cloud masking."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import ee\n",
    "import pandas as pd\n",
    "\n",
    "from sebal import (\n",
    "    build_landsat_mosaic,\n",
    "    load_era5_meteorology,\n",
    "    compute_albedo_tasumi,\n",
    "    compute_net_radiation,\n",
    "    compute_soil_heat_flux,\n",
    "    select_anchor_pixels,\n",
    "    solve_sensible_heat_cimec,\n",
    "    compute_daily_et,\n",
    ")\n",
    "from sebal.albedo import compute_ndvi, compute_emissivity\n",
    "from sebal.radiation import compute_air_density\n",
    "from sebal.sensible_heat import compute_roughness, compute_neutral_aerodynamics\n",
    "from sebal.era5 import load_era5_daily_rn\n",
    "from sebal.utils import init_ee, load_aoi, stations_to_feature_collection, extract_at_stations, export_to_drive"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Earth Engine authentication"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "EE_PROJECT = 'your-ee-project-id'   # <-- REPLACE with your project id\n",
    "init_ee(EE_PROJECT)\n",
    "print('Earth Engine ready.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. AOI + stations"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "_, _, aoi_geom = load_aoi('../data/thrace_boundary.geojson')\n",
    "\n",
    "stations = pd.DataFrame([\n",
    "    {'name': 'Edirne',      'lat': 41.6667, 'lon': 26.5667, 'elevation_m':  51},\n",
    "    {'name': 'Kirklareli',  'lat': 41.7333, 'lon': 27.2167, 'elevation_m': 232},\n",
    "    {'name': 'Luleburgaz',  'lat': 41.4000, 'lon': 27.3500, 'elevation_m':  46},\n",
    "    {'name': 'Uzunkopru',   'lat': 41.2667, 'lon': 26.6833, 'elevation_m':  22},\n",
    "    {'name': 'Ipsala',      'lat': 40.9167, 'lon': 26.3833, 'elevation_m':  10},\n",
    "    {'name': 'Corlu',       'lat': 41.1500, 'lon': 27.8000, 'elevation_m': 183},\n",
    "    {'name': 'Tekirdag',    'lat': 40.9833, 'lon': 27.5167, 'elevation_m':   3},\n",
    "    {'name': 'Sariyer',     'lat': 41.1667, 'lon': 29.0500, 'elevation_m':  59},\n",
    "])\n",
    "stations_fc = stations_to_feature_collection(stations)\n",
    "print(f'AOI area: {aoi_geom.area().divide(1e6).getInfo():,.0f} km^2')\n",
    "print(f'Stations: {stations_fc.size().getInfo()}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Landsat 8+9 mosaic"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "ANCHOR = '2023-07-20'\n",
    "WINDOW_DAYS = 14\n",
    "\n",
    "mosaic, _, coverage = build_landsat_mosaic(aoi_geom, ANCHOR, WINDOW_DAYS)\n",
    "print(f'Mosaic coverage over AOI: {coverage:.1f}%')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. ERA5-Land meteorology (window mean at overpass hour)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "start = ee.Date(ANCHOR).advance(-WINDOW_DAYS // 2, 'day')\n",
    "end = ee.Date(ANCHOR).advance(WINDOW_DAYS // 2, 'day')\n",
    "\n",
    "era5 = load_era5_meteorology(aoi_geom, start, end)\n",
    "rn_24h = load_era5_daily_rn(aoi_geom, start, end)\n",
    "print('ERA5-Land meteorology and daily Rn loaded.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Albedo, NDVI, emissivity, LST"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "albedo = compute_albedo_tasumi(mosaic)\n",
    "ndvi = compute_ndvi(mosaic)\n",
    "emissivity = compute_emissivity(ndvi)\n",
    "lst_k = mosaic.select('LST_K')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Energy balance: Rn, G, Rn-G"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "rn = compute_net_radiation(albedo,\n",
    "                            era5.select('Rs_in'),\n",
    "                            era5.select('Rl_in'),\n",
    "                            lst_k,\n",
    "                            emissivity)\n",
    "G, _ = compute_soil_heat_flux(rn, lst_k, albedo, ndvi)\n",
    "rn_minus_g = rn.subtract(G).rename('Rn_minus_G')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Anchor pixel selection (cold and hot extremes)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "cold_stats, hot_stats, cold_mask, hot_mask = select_anchor_pixels(\n",
    "    ndvi, lst_k, albedo, rn, G, aoi_geom\n",
    ")\n",
    "print('Cold anchor:', {k: round(v, 3) for k, v in cold_stats.items() if v is not None})\n",
    "print('Hot anchor: ', {k: round(v, 3) for k, v in hot_stats.items() if v is not None})"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Aerodynamics + CIMEC iterative H"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "z0m = compute_roughness(ndvi)\n",
    "u_star, u_200, r_ah_init = compute_neutral_aerodynamics(era5.select('wind_10m'), z0m)\n",
    "rho_air = compute_air_density(era5.select('P_surf'), era5.select('T_air_K'))\n",
    "\n",
    "H, r_ah, fit = solve_sensible_heat_cimec(\n",
    "    lst_k, rho_air, u_star, u_200, z0m, r_ah_init,\n",
    "    rn_minus_g, cold_mask, hot_mask, cold_stats, hot_stats, aoi_geom\n",
    ")\n",
    "print(f'\\nFinal dT fit: dT = {fit[\"a_intercept\"]:.3f} + {fit[\"b_slope\"]:.4f} * Ts')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 9. Daily ET via Evaporative Fraction"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "LE = rn_minus_g.subtract(H).max(ee.Image(0)).rename('LE')\n",
    "et_daily, ef = compute_daily_et(LE, rn_minus_g, rn_24h, era5.select('T_air_K'))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 10. Station-level summary table"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "summary = ee.Image.cat([ndvi, albedo, lst_k.rename('LST_K'), rn, G, H, LE, ef, et_daily])\n",
    "df = extract_at_stations(summary, stations_fc, scale=30)\n",
    "df['LST_C'] = (df['LST_K'] - 273.15).round(1)\n",
    "cols = ['name', 'NDVI', 'albedo', 'LST_C', 'Rn', 'G', 'H', 'LE', 'EF', 'ET_daily_mm']\n",
    "df = df[cols].round(2)\n",
    "print('SEBAL MVP - Thrace - 2023-07-20 +/- 7 days')\n",
    "df"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 11. Export daily ET to Drive as GeoTIFF"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "task = export_to_drive(\n",
    "    image=et_daily,\n",
    "    description='Thrace_Daily_ET_2023-07-20',\n",
    "    aoi_geom=aoi_geom,\n",
    ")\n",
    "print('Export task started. Check Google Drive > sebal_et_gee_exports folder.')\n",
    "print(f'Task ID: {task.id}')"
   ]
  }
 ],
